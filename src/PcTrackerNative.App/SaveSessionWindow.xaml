<Window x:Class="PcTrackerNative.App.SaveSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Session"
        Height="420"
        Width="620"
        MinHeight="380"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFF7F7F9">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock x:Name="SummaryTextBlock"
                   Grid.Row="0"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#FF111827"
                   Text="Save this session" />

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,18,0,0" VerticalAlignment="Top" Text="Description" />
        <TextBox x:Name="DescriptionTextBox"
                 Grid.Row="1"
                 Grid.Column="1"
                 Margin="0,18,0,0"
                 Height="96"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" />

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,14,0,0" VerticalAlignment="Center" Text="Difficulty" />
        <ComboBox x:Name="DifficultyComboBox"
                  Grid.Row="2"
                  Grid.Column="1"
                  Margin="0,14,0,0"
                  Width="160"
                  HorizontalAlignment="Left" />

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,14,0,0" VerticalAlignment="Top" Text="Notes" />
        <TextBox x:Name="NotesTextBox"
                 Grid.Row="3"
                 Grid.Column="1"
                 Margin="0,14,0,0"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" />

        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Width="110" Height="34" Margin="0,0,8,0" Content="Discard" Click="DiscardButton_Click" />
            <Button Width="110" Height="34" Content="Save" Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
